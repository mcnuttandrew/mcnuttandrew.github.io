{
  "extends": "@tsconfig/svelte/tsconfig.json",

  "include": ["src/**/*"],
  "exclude": ["node_modules/*", "__sapper__/*", "build/*"],
  "compilerOptions": {
    "target": "esnext",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "markdown-it": ["./src/types/markdown-it"]
    }
  }
}